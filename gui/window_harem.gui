				# 		using = tooltip_ws
				# 	}
				# }

				# portrait_council = {
				# 	name = "councillor_portrait_blank_liege"
				# 	visible = "[And( Not(Character.IsValid), CouncilWindow.IsLiegeCouncilShown )]"
				# 	parentanchor = center

				# 	text_label_center = {
