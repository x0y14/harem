					# }

					# 家系の人間とかのあいこん
					flowcontainer = {
						parentanchor = bottom
						# margin_left = 50
						margin_right = 50
						margin_bottom = 4

						portrait_status_icons = {
							background = {
								using = Background_Area_Dark
								margin = { 1 2 }
							}
						}
					}

