				# 		text = "COUNCILLOR_CLICK_TO_HIRE"
				# 		default_format = "#low;italic"
				# 		max_width = 235
				# 	}

				# 	blockoverride "onclick" {
				# 		onclick = "[GuiCouncilPosition.SelectCouncillor]"

